# ============================================
# Nazar — Git Ignore
# ============================================

# Environment variables (SECRETS)
.env
.env.local
.env.production
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/

# Database files (local)
*.db
*.sqlite3
chroma_db/

# Node.js
node_modules/
.next/
out/
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Test coverage
htmlcov/
.coverage
.pytest_cache/

# Misc
*.bak
*.tmp
